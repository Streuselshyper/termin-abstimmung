# Umgebungsvariablen für Termin-Abstimmung
# Kopiere diese Datei: cp .env.example .env
# Trage dann deine eigenen Werte ein

# Server-Konfiguration
PORT=18793
NODE_ENV=production

# Session-Sicherheit
# MINDESTENS 32 Zeichen - Generiere z.B. mit: openssl rand -base64 32
SESSION_SECRET=trage-hier-ein-sehr-langes-zufälliges-passwort-ein

# Datenbank
# SQLite wird verwendet - Pfad relativ zum Projektordner
DATABASE_PATH=./data/termin-abstimmung.db

# E-Mail-Konfiguration (z.B. SendGrid)
# 1. Account erstellen bei sendgrid.com
# 2. API Key generieren
# 3. Sender-Adresse verifizieren
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=dein-sendgrid-api-key-hier-einfügen
SMTP_FROM=noreply@deine-domain.de

# Optional: E-Mail-Benachrichtigungen
# Deaktivieren wenn keine E-Mails versendet werden sollen
ENABLE_EMAIL_NOTIFICATIONS=true

# Optional: Tägliche Zusammenfassung
# Benutzer bekommen täglich eine Mail mit neuen Antworten
DAILY_SUMMARY=true
